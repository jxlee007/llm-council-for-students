    focusedLabelColor = CouncilCyan,
    unfocusedLabelColor = CouncilTextSecondary,
    focusedTextColor = CouncilTextPrimary,
    unfocusedTextColor = CouncilTextPrimary,
    cursorColor = CouncilCyan,
)
