<?xml version="1.0" encoding="utf-8"?>
<!--
  data_extraction_rules.xml — defines what is backed up by Android data backup
  and what is excluded from cloud backups.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude local.properties-equivalent DataStore prefs from cloud backup
             since they contain the user's API key. -->
        <exclude domain="sharedpref" path="council_settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="council_settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
