# ─── Local Configuration ─────────────────────────────────────────────────────
# Copy this file to local.properties and fill in the values.
# NEVER commit local.properties to version control.

# Atlas App ID from the MongoDB Atlas App Services console.
# Create a free cluster at https://www.mongodb.com/atlas/database
# Then set up App Services with email/password auth and Device Sync enabled.
ATLAS_APP_ID=your-atlas-app-id

# Default FastAPI backend URL.
# Use 10.0.2.2 for Android emulator → localhost on host machine.
# Use your LAN IP or ngrok URL for a real device.
DEFAULT_API_URL=http://10.0.2.2:8001

# The OpenRouter API key is stored at runtime via the Settings screen.
# You do NOT need to put it here — it is saved locally in DataStore on the device.
# Get one at https://openrouter.ai/keys

# Android SDK location (auto-generated by Android Studio)
sdk.dir=/home/user/Android/Sdk
