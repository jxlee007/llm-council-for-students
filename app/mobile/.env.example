# ==============================================================================
# Expo Mobile Application Environment Variables Template
# Copy this file to '.env' or '.env.local' and fill in your actual values.
# ==============================================================================

# Current Environment ('development', 'preview', or 'production')
APP_ENV=development
EXPO_PUBLIC_APP_VARIANT=development

# ------------------------------------------------------------------------------
# 📱 Public Runtime Variables (Mandatory 'EXPO_PUBLIC_' prefix)
# These will be bundled into the compiled application.
# ------------------------------------------------------------------------------

# The HTTP API endpoint of your local server or hosted backend
EXPO_PUBLIC_API_URL=http://localhost:8001

# Clerk Publishable Key (Authentication)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Convex Backend URL
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Sentry DSN (Error Tracking & Diagnostics)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ------------------------------------------------------------------------------
# 🔒 Build-Time Secrets (NO 'EXPO_PUBLIC_' prefix)
# Used only during local builds or EAS Cloud builds. Do NOT use prefix so they are not bundled.
# ------------------------------------------------------------------------------

# EAS Project Identification
EAS_PROJECT_ID=044eb304-db9b-49c9-9b3f-7d03bb4f0edd

# Sentry Auth Token (used for uploading sourcemaps during build)
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=test-4ek
SENTRY_PROJECT=llm-council
SENTRY_DISABLE_AUTO_UPLOAD=true
